{
  "name": "spot-music",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "node scripts/generate-icons.mjs && tsc -b && vite build",
    "build:prod": "npm run build",
    "postinstall": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "start:win": "set NODE_ENV=production&& node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "firebase": "^11.6.0",
    "idb": "^8.0.2",
    "lucide-react": "^0.487.0",
    "play-dl": "^1.9.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "youtube-dl-exec": "^3.1.8",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^0.21.2"
  }
}
